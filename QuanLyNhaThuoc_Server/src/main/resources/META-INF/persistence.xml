<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="quanlyhieuthuoc-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>entity.BangGia</class>
        <class>entity.ChiTietBangGia</class>
        <class>entity.ChiTietHoaDon</class>
        <class>entity.ChiTietKhuyenMaiSanPham</class>
        <class>entity.ChiTietPhieuHuy</class>
        <class>entity.ChiTietPhieuNhap</class>
        <class>entity.ChiTietPhieuTra</class>
        <class>entity.DonViTinh</class>
        <class>entity.HoaDon</class>
        <class>entity.KhachHang</class>
        <class>entity.KhuyenMai</class>
        <class>entity.LoSanPham</class>
        <class>entity.NhaCungCap</class>
        <class>entity.NhanVien</class>
        <class>entity.PhieuHuy</class>
        <class>entity.PhieuNhap</class>
        <class>entity.PhieuTra</class>
        <class>entity.QuyCachDongGoi</class>
        <class>entity.SanPham</class>
        <class>entity.TaiKhoan</class>

        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.mariadb.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mariadb://localhost:3306/QuanLyHieuThuoc?createDatabaseIfNotExist=true&amp;useUnicode=true&amp;characterEncoding=UTF-8"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="sapassword"/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.MariaDBDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
